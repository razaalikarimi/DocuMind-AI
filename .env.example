# =============================================================================
# AI PDF CHAT SAAS — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values
# =============================================================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="DocuMind AI"
NODE_ENV=development

# =============================================================================
# CLERK AUTHENTICATION
# Get from: https://dashboard.clerk.com
# =============================================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# =============================================================================
# MONGODB ATLAS
# Get from: https://cloud.mongodb.com
# =============================================================================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/documind?retryWrites=true&w=majority
MONGODB_DB_NAME=documind

# =============================================================================
# UPSTASH REDIS (serverless Redis, Vercel-compatible)
# Get from: https://console.upstash.com
# =============================================================================
UPSTASH_REDIS_REST_URL=https://xxxxxxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxxxxxxxxxxxxxxxxxxxx

# For BullMQ (requires standard Redis connection)
REDIS_URL=redis://default:password@xxxxxxxxxxxx.upstash.io:6379

# =============================================================================
# OPENAI
# Get from: https://platform.openai.com
# =============================================================================
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_DIMENSIONS=1536

# =============================================================================
# UPLOADTHING
# Get from: https://uploadthing.com/dashboard
# =============================================================================
UPLOADTHING_SECRET=sk_live_xxxxxxxxxxxxxxxxxxxx
UPLOADTHING_APP_ID=xxxxxxxxxxxxxxxxxxxx

# =============================================================================
# SENTRY
# Get from: https://sentry.io
# =============================================================================
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxx@xxxxxxxx.ingest.sentry.io/xxxxxxx
SENTRY_ORG=your-org
SENTRY_PROJECT=documind-ai
SENTRY_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxx

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_API_REQUESTS=60
RATE_LIMIT_CHAT_REQUESTS=10
RATE_LIMIT_UPLOAD_REQUESTS=5

# =============================================================================
# AI / RAG CONFIG
# =============================================================================
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=8
RAG_SIMILARITY_THRESHOLD=0.75
RAG_MAX_CONTEXT_TOKENS=3000
RAG_CONVERSATION_MEMORY_TURNS=6

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_ANALYTICS=true
ENABLE_AUDIT_LOGS=true
ENABLE_RATE_LIMITING=true
